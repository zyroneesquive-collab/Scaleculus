---
import Topics from "../data/topics.json";

import MainLayout from "../layouts/main_layout.astro";
import SectionElement from "../components/SectionElement.astro";
import HorizontalSection from "../components/HorizontalSection.astro"
import HorSection2 from "../components/Hor-Section2.astro";
import Sidebar from '../components/Sidebar.astro';
import { Button } from 'free-astro-components';

import Accordion from "../components/Accordion.astro";

---

<MainLayout>
	<Sidebar currentPage="Homepage">
	</Sidebar>

	<section class = "Section-con2">
	<HorizontalSection title="About Scaleculus" direction = "center" fontsize1 = "3rem" fontsize2 = "1.25rem" justifycontent = "center" width = "30%">
		<section>
			Scaleculus is a student-built, non-profit platform made for learners by learners. <br><br>
			It offers one of the most interactive ways for Grade 11 students to master calculus concepts. <br><br>
			
			With engaging lessons and fun educational games, Scaleculus turns learning into an exciting adventure!
		</section>	
	</HorizontalSection>

	<HorizontalSection title="What We Offer" direction = "center" fontsize1 = "3rem" fontsize2 = "1.25rem" justifycontent = "center" width = "30%">
		<section>
				Scaleculus makes learning calculus fun! Explore lessons on Limits, Continuity, Tangent Lines, Differentiation, and the Chain Rule. 
				<br>
				<br>
				Play interactive games in our Arcade while practicing what you learn!
		</section>	
	</HorizontalSection>

	</section>
	
	
		<HorSection2 title = "Dive In" direction = "center" fontsize1 = "3rem" fontsize2 = "1.5rem" justifycontent = "center" width = "100%" height = "70vh">
			<section class = "Section-con">
				<a href="/Scaleculus/Lessons/">
				<SectionElement title = "Explore Concepts 🕮 " direction = "left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" height = "20rem" width = "30rem">
					<section>
						Understand key ideas quickly.
					</section>
					
				</SectionElement>
				</a>
				<a href="/Scaleculus/Games/">
				<SectionElement title = "Play games 🖳" direction = "left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" height = "20rem" width = "30rem">
					<section>
						Learn while having fun.
					</section>
				</SectionElement>
				</a>

				<a href="/Scaleculus/About/">
				<SectionElement title = "About Us ✎ " direction = "left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" height = "20rem" width = "30rem">
					<section>
						Learn more about this Website
					</section>
				</SectionElement>
				</a>
			</section>
		</HorSection2>
		
		<HorSection2 title = "Lessons" direction = "center" fontsize1 = "3rem" fontsize2 = "1.5rem" justifycontent = "center" width = "100%" height = "70vh">
			<section class = "Section-con">

			<a href="/Scaleculus/Limits/" >
			<HorSection2 title = "Limits" direction = "Left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" justifycontent = "flex-start" width = "40rem" height = "30vh">
					A value that a function approaches as the input approaches a certain number. 
			</HorSection2>
			</a>

			<a href="/Scaleculus/Continuity/" >
			<HorSection2 title = "Continuity" direction = "Left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" justifycontent = "flex-start" width = "40rem" height = "30vh">
					A function is said to be continuous in a given interval if there is no break in the graph of the function in the entire interval range.
			</HorSection2>
			</a>

			<a href="/Scaleculus/Slope/" >
			<HorSection2 title = "Slope of a Tangent Line" direction = "Left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" justifycontent = "flex-start" width = "40rem" height = "30vh">
					It is the instantaneous rate of change of a function.
			</HorSection2>
			</a>

			<a href="/Scaleculus/Differentiation/" >
			<HorSection2 title = "Differentiation Rules of Algebraic Expressions" direction = "Left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" justifycontent = "flex-start" width = "40rem" height = "30vh">
					The process of finding the derivative of algebraic functions.
			</HorSection2>	
			</a>

			<a href="/Scaleculus/Differentiation/" >
			<HorSection2 title = "Chain Rule and Implicit Differentiation" direction = "Left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" justifycontent = "flex-start" width = "40rem" height = "30vh">
					Used to differentiate composite functions.
			</HorSection2>
			</a>

			<HorSection2 title = "What is Calculus?" direction = "Left" fontsize1 = "2.5rem" fontsize2 = "1.5rem" justifycontent = "flex-start" width = "40rem" height = "30vh">
					A branch of mathematics that studies continuous change and motion using limits and derivatives.
			</HorSection2>

			</section>
		</HorSection2>

		<HorSection2 title = "About Us" direction = "center" fontsize1 = "3rem" fontsize2 = "2rem" justifycontent = "center" width = "100%" height = "10vh">
			Scaleculus. The educational website where Grade 11 Calculus is made simple and fun.
		</HorSection2>
		<HorSection2 title = "Frequently Asked Questions (FAQs)" direction = "center" fontsize1 = "3rem" fontsize2 = "2rem" justifycontent = "center" width = "100%" height = "10vh">
			Common Questions<br><br>
			<Accordion
        title="What is Scaleculus?"
        id="What is Scaleculus?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        Scaleculus is an interactive learning website for students to explore calculus concepts.<br>
        </Accordion>

		<Accordion
        title="How do I navigate the website?"
        id="How do I navigate the website?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        Use the Home Button, table of contents, and links on each page to access lessons, exercises, and games.<br>
        </Accordion>

		<Accordion
        title="What are the different calculus topics covered?"
        id="What are the different calculus topics covered?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        The website covers limits, derivatives, chain rule, implicit differentiation and related problem-solving exercises<br>
        </Accordion>

		<Accordion
        title="How can I track my learning progress?"
        id="How can I track my learning progress?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        Keep notes of completed lessons and scores from the games to monitor your improvement.<br>
        </Accordion>

		<Accordion
        title="Can I access the website on mobile devices?"
        id="Can I access the website on mobile devices?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        Yes, but the website is primarily design for larger monitor viewing use computers.<br>
        </Accordion>

		<Accordion
        title="Is my data private when using the website?"
        id="Is my data private when using the website?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        Yes, the website does not collect personal data beyond basic usage analytics for improving the site.<br>
        </Accordion>

		<Accordion
        title="Can I suggest topics or improvements for the site?"
        id="Can I suggest topics or improvements for the site?"
        direction="left"
        justifycontent="flex-start"
        fontsize1="2rem"
        fontsize2="1.5rem"
		width = "99%"
		height = "auto"
        >
        Yes, suggestions are welcome through the contact form or email.<br>
        </Accordion>

		</HorSection2>
		
	
</MainLayout>

<style>
	html, body {
    overflow-x: hidden; 
}

	:root {
    --wisteria: #BEADDCff;
    --shadow-grey: #141527ff;
    --petal-frost: #F7D3EBff;
    --thistle: #D7BCE4ff;
    --wisteria-2: #C493DAff;
    --amethyst-smoke: #C18EC7ff;
    --snow: #F8EEEDff;
    }

	

	.Section-con {
		display: flex;
		flex-wrap: wrap;
		align-items: center;

		gap: 2rem;
		justify-content: center; 
	}

	.Section-con2 {
    display: flex;               
    flex-wrap: wrap;            
    align-items: center;          
    justify-content: center;     
    gap: 1rem;

    width: 100%;
    min-height: 100vh;          

    background-color: rgba(20, 21, 39, 0.4);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);

    border: 2px solid var(--wisteria-2);
    border-radius: 1rem;
    box-shadow: 0 0 1rem rgba(193, 142, 199, 0.4);

	margin-bottom: 10rem;

    padding: 2rem;
    position: relative;
    z-index: 1;

    box-sizing: border-box;
	}

</style>