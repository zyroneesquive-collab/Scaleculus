    </main>
  </div>
</SubLayout>

<style>
:root {
  --wisteria: rgb(190, 173, 220);
  --snow: #F8EEED;
  --shadow-grey: rgb(20,21,39);
}

html {
  scroll-behavior: smooth;
}

.Spacer { margin-top: 10rem; }

/* TOC Island */
.page-wrapper {
  display: flex;
  gap: 2rem;                /* space between TOC and content */
  min-height: 100vh;        /* full viewport height */
}

.toc {
  flex-shrink: 0;
  position: fixed;           /* fixed on screen */
  top: 0;
  left: 0;
  height: 100vh;             /* full viewport height */
  padding: 2rem 1em;
  width: 14em;
  background: rgba(30, 20, 39, 0.95);
  border-radius: 0 1rem 1rem 0;
  box-shadow: 0 0 1rem rgba(190,173,220,0.5);
  z-index: 1;

  display: flex;
  flex-direction: column;
  justify-content: center;   /* center TOC items vertically */
}

.main-content {
  flex: 1;
  margin-left: 16em; /* TOC width + a little extra gap so nothing overlaps */
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4rem; /* vertical spacing between HorSection2 and Accordion */
  padding: 2rem;
}

.toc ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.toc ul ul {
  padding-left: 1.5em;
}

.toc li a {
  display: inline-block;
  color: var(--snow);
  font-weight: 1000;
  text-decoration: none;
  font-family: "Quicksand", sans-serif;
  font-size: 1.3rem;       /* bigger font size */
  padding: 0.5rem 0 2rem 0; /* keep vertical spacing */
  transition: all 0.3s ease;
}

.toc li a.visible {
  color: var(--wisteria);
  font-weight: 1000;
  transform: translateX(5px);
}

.toc-marker {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.toc-marker path {
  transition: all 0.3s ease;
}

/* Push main content to the right so TOC doesn’t overlap */
.contents {
  margin-left: 16em; /* TOC width + small gap */
  max-width: 800px;
  padding: 1em;
  font-family: 'Quicksand', sans-serif;
}
</style>

<script is:inline>
  // Floating TOC Scroll Tracking
  var toc = document.querySelector('.toc');
  var tocPath = toc.querySelector('.toc-marker path');
  var tocItems;
  var TOP_MARGIN = 0.1, BOTTOM_MARGIN = 0.2;
  var pathLength;
  var lastPathStart, lastPathEnd;

  window.addEventListener('resize', drawPath);
  window.addEventListener('scroll', sync);

  drawPath();

  function drawPath() {
  tocItems = Array.from(toc.querySelectorAll('li')).map(item => {
    var anchor = item.querySelector('a');
    var target = document.getElementById(anchor.getAttribute('href').slice(1));
    return { listItem: item, anchor: anchor, target: target };
  }).filter(item => !!item.target);

  var path = [], pathIndent;

  tocItems.forEach((item, i) => {
    const rect = item.anchor.getBoundingClientRect(); // use rendered size
    const x = item.anchor.offsetLeft - 5;
    const y = item.anchor.offsetTop;
    const height = rect.height; // fully accounts for padding

    if (i === 0) {
      path.push('M', x, y, 'L', x, y + height);
      item.pathStart = 0;
    } else {
      if (pathIndent !== x) path.push('L', pathIndent, y);
      path.push('L', x, y);
      tocPath.setAttribute('d', path.join(' '));
      item.pathStart = tocPath.getTotalLength() || 0;
      path.push('L', x, y + height);
    }
    pathIndent = x;
    tocPath.setAttribute('d', path.join(' '));
    item.pathEnd = tocPath.getTotalLength();
  });

  pathLength = tocPath.getTotalLength();
  sync();
}

  function sync() {
    var windowHeight = window.innerHeight;
    var pathStart = pathLength, pathEnd = 0;
    var visibleItems = 0;

    tocItems.forEach(item => {
      var targetBounds = item.target.getBoundingClientRect();
      if(targetBounds.bottom > windowHeight * TOP_MARGIN &&
         targetBounds.top < windowHeight * (1 - BOTTOM_MARGIN)) {
        pathStart = Math.min(item.pathStart, pathStart);
        pathEnd = Math.max(item.pathEnd, pathEnd);
        visibleItems += 1;
        item.anchor.classList.add('visible');
      } else {
        item.anchor.classList.remove('visible');
      }
    });

    if (visibleItems > 0 && pathStart < pathEnd) {
      tocPath.setAttribute('stroke-dashoffset', '1');
      tocPath.setAttribute('stroke-dasharray', `1, ${pathStart}, ${pathEnd - pathStart}, ${pathLength}`);
      tocPath.setAttribute('opacity', 1);
    } else {
      tocPath.setAttribute('opacity', 0);
    }

    lastPathStart = pathStart;
    lastPathEnd = pathEnd;
  }
</script>