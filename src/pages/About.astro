---
import Topics from "../data/topics.json";

import SubLayout from "../layouts/sub_layout.astro";
import HorizontalSection from "../components/HorizontalSection.astro";
import Accordion from "../components/Accordion.astro";
import Sidebar from '../components/Sidebar.astro';
---

<SubLayout>
  <Sidebar currentPage="About" />

  <div class="Spacer"></div>

  <HorizontalSection title="About this Site:" direction="left" fontsize1="3rem" fontsize2="2rem" justifycontent="center" width="100%">
    Scaleculus is a student-built, non-profit platform made for learners by learners.<br>
    It offers one of the most interactive ways for Grade 11 students to master calculus concepts.<br>
    With engaging lessons and fun educational games, Scaleculus turns learning into an exciting adventure!<br><br>
  </HorizontalSection>

  <HorizontalSection title="What We Offer:" direction="left" fontsize1="3rem" fontsize2="2rem" justifycontent="center" width="100%">
    Scaleculus makes learning calculus fun! Explore lessons on Limits, Continuity, Tangent Lines, Differentiation, and the Chain Rule.<br>
    Play interactive games in our Arcade while practicing what you learn!<br>
  </HorizontalSection>

  <HorizontalSection title="Members:" direction="left" fontsize1="3rem" fontsize2="2rem" justifycontent="center" width="100%">
    Made by 11-STEM-Scalable
  </HorizontalSection>

  <HorizontalSection title="Frequently Asked Questions (FAQs)" direction="center" fontsize1="3rem" fontsize2="2rem" justifycontent="center" width="100%" height="10vh">
    Common Questions<br><br>

    <Accordion
      title="What is Scaleculus?"
      id="What is Scaleculus?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      Scaleculus is an interactive learning website for students to explore calculus concepts.<br>
    </Accordion>

    <Accordion
      title="How do I navigate the website?"
      id="How do I navigate the website?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      Use the Home Button, table of contents, and links on each page to access lessons, exercises, and games.<br>
    </Accordion>

    <Accordion
      title="What are the different calculus topics covered?"
      id="What are the different calculus topics covered?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      The website covers limits, derivatives, chain rule, implicit differentiation and related problem-solving exercises<br>
    </Accordion>

    <Accordion
      title="How can I track my learning progress?"
      id="How can I track my learning progress?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      Keep notes of completed lessons and scores from the games to monitor your improvement.<br>
    </Accordion>

    <Accordion
      title="Can I access the website on mobile devices?"
      id="Can I access the website on mobile devices?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      Yes, but the website is primarily designed for larger monitor viewing on computers.<br>
    </Accordion>

    <Accordion
      title="Is my data private when using the website?"
      id="Is my data private when using the website?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      Yes, the website does not collect personal data beyond basic usage analytics for improving the site.<br>
    </Accordion>

    <Accordion
      title="Can I suggest topics or improvements for the site?"
      id="Can I suggest topics or improvements for the site?"
      direction="left"
      justifycontent="flex-start"
      fontsize1="2rem"
      fontsize2="1.5rem"
      width="99%"
      height="auto"
    >
      Yes, suggestions are welcome through the contact form or email.<br>
    </Accordion>

  </HorizontalSection>
</SubLayout>

<style>
  html,
  body {
    overflow-x: hidden;
  }

  .Spacer {
    margin-top: 10rem;
  }

  :root {
    --wisteria: #BEADDCff;
    --shadow-grey: #141527ff;
    --petal-frost: #F7D3EBff;
    --thistle: #D7BCE4ff;
    --wisteria-2: #C493DAff;
    --amethyst-smoke: #C18EC7ff;
    --snow: #F8EEEDff;
  }

  .Section-con {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
    justify-content: center;
  }
</style>
    align-items: center;
    justify-content: center;
    gap: 1rem;

    width: 100%;
    min-height: 100vh;

    background-color: rgba(20, 21, 39, 0.4);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);

    border: 2px solid var(--wisteria-2);
    border-radius: 1rem;
    box-shadow: 0 0 1rem rgba(193, 142, 199, 0.4);

    margin-bottom: 10rem;
    padding: 2rem;
    position: relative;
    z-index: 1;

    box-sizing: border-box;
  }
</style>
