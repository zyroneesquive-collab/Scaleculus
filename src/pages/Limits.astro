            </tr>
            <tr><td>-1</td><td>57.2987</td></tr>
            <tr><td>-0.5</td><td>57.2965</td></tr>
            <tr><td>-0.1</td><td>57.2958</td></tr>
            <tr><td>-0.01</td><td>57.2958</td></tr>
            <tr><td>-0.001</td><td>57.2958</td></tr>
        </table><br>

        <p>Right-hand approach (x → 0⁺):</p>
        <table border="1" cellpadding="5" cellspacing="0">
            <tr>
                <th>x</th>
