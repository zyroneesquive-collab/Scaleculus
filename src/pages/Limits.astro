---
import Topics from "../data/topics.json";
import SubLayout from "../layouts/sub_layout.astro";
import HorSection2 from "../components/Hor-Section2.astro";
import Sidebar from '../components/Sidebar.astro';
---

<SubLayout title={Topics.Titles[0]}>
  <Sidebar currentPage="Limits" />

  <div class="Spacer"></div>

  <!-- What is Limits -->
  <HorSection2 title="What is Limits?" direction="center" fontsize1="3rem" fontsize2="1.5rem" justifycontent="center" width="100%" height="auto">
    <section class="ExampleText">
      A limit is a value that a function approaches as the input approaches a certain number.<br>
      General form: y = a•bˣ where:<br>
      • a is a constant (initial value)<br>
      • b is the base, typically a positive real number<br>
      • x is the exponent<br>
      Exponential function: f(x) = a • t
    </section>
  </HorSection2>

  <!-- LIMITS USING DS: EXPONENTIAL FUNCTION -->
  <HorSection2 title="LIMITS USING DS: EXPONENTIAL FUNCTION" direction="center" fontsize1="3rem" fontsize2="1.5rem" justifycontent="center" width="100%" height="auto">

    <HorSection2 title="Example 1: Solve 2ˣ = 8" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Solution: Express both sides with the same base → 2ˣ = 2³<br>
        Set exponents equal → x = 3<br>
        Result: x = 3
      </section>
    </HorSection2>

    <HorSection2 title="Example 2: Solve 5•3ˣ = 45" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Divide both sides by 5 → 3ˣ = 9<br>
        Rewrite 9 as power of 3 → 3ˣ = 3²<br>
        Set exponents equal → x = 2<br>
        Result: x = 2
      </section>
    </HorSection2>

    <HorSection2 title="Example 3: Fractional Exponent (Radical Form)" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Problem: lim 9^(x/2), x→4<br>
        Substitute x = 4 → 9^(4/2) = 9²<br>
        Evaluate → 9² = 81<br>
        Result: The limit is 81
      </section>
    </HorSection2>

    <HorSection2 title="Example 4: Power Function Limit" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Problem: lim (x-1)^(x+1), x→3<br>
        Base: 3-1=2, Exponent: 3+1=4<br>
        Evaluate → 2⁴ = 16<br>
        Result: The limit is 16
      </section>
    </HorSection2>

  </HorSection2>

  <!-- LIMITS USING DS: TRIGONOMETRIC FUNCTION -->
  <HorSection2 title="LIMITS USING DS: TRIGONOMETRIC FUNCTION" direction="center" fontsize1="3rem" fontsize2="1.5rem" justifycontent="center" width="100%" height="auto">

    <HorSection2 title="Definition" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Trigonometric functions are functions of an angle. The basic trigonometric functions are:<br>
        Sine: sin(θ)<br>
        Cosine: cos(θ)<br>
        Tangent: tan(θ)<br>
        Secant: sec(θ)<br>
        Cosecant: csc(θ)<br>
        Cotangent: cot(θ)
      </section>
    </HorSection2>

    <HorSection2 title="Basic Sine Limit" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Problem: lim sin(x), x→30°<br>
        Solution: sin(30°) = ½<br>
        Result: 1/2
      </section>
    </HorSection2>

    <HorSection2 title="Basic Tangent Limit" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Problem: lim tan(x), x→45°<br>
        Solution: tan(45°) = 1<br>
        Result: 1
      </section>
    </HorSection2>

    <HorSection2 title="Composite Root-Trig Limit" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Problem: lim √(2cos(x)), x→π/3<br>
        Solution: cos(π/3) = ½, multiply by 2 → √(2•½) = √1 = 1<br>
        Result: 1
      </section>
    </HorSection2>

    <HorSection2 title="Reciprocal Product Limit" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Problem: lim sec²(x)•sin(x), x→π/6<br>
        Solution: sec(π/6) = 2/√3, sin(π/6) = ½ → (2/√3)² • ½ = 2/3<br>
        Result: 2/3
      </section>
    </HorSection2>

  </HorSection2>

  <!-- LIMITS USING DS: LOGARITHMIC FUNCTION -->
  <HorSection2 title="LIMITS USING DS: LOGARITHMIC FUNCTION" direction="center" fontsize1="3rem" fontsize2="1.5rem" justifycontent="center" width="100%" height="auto">

    <HorSection2 title="Example 1: lim log₂(x) = 5" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Rewrite in exponential form: 2⁵ = x → x = 32<br>
        Result: 32
      </section>
    </HorSection2>

    <HorSection2 title="Example 2: lim log₃(x) = 4" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Rewrite in exponential form: 3⁴ = x → x = 81<br>
        Result: 81
      </section>
    </HorSection2>

    <HorSection2 title="Example 3: lim log₂(2x-5), x→3" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Substitute x = 3 → log₂(2•3-5) = log₂1 → 0<br>
        Result: 0
      </section>
    </HorSection2>

    <HorSection2 title="Example 4: lim log₁₀(2x/(x-4)), x→5" direction="center" justifycontent="center" width="100%" height="auto">
      <section class="ExampleText">
        Substitute x = 5 → 2•5 / (5-4) = 10<br>
        Apply log₁₀ → log₁₀10 = 1<br>
        Result: 1
      </section>
    </HorSection2>

  </HorSection2>

</SubLayout>

<style>
  .Spacer {
    margin-top: 5rem;
  }

  .ExampleText {
    font-size: 1.25rem;
    line-height: 1.8;
    text-align: left;
  }
</style>