---
const { isOpen = false, currentPage = "" } = Astro.props;
---

<!-- Permanent home button top-left -->
<button class="Home-Button">
    <img src="/Scaleculus/icons/home.png" alt="Home Icon" />
</button>

<div class="Sidebar" data-open={isOpen}>
    <div class="Sidebar-Content">
        <nav>
            <a href="/Scaleculus/" class={currentPage === "Homepage" ? "active" : ""}>Homepage</a>

            <div class="Divider"></div>

            <a href="/Scaleculus/Limits/" class={currentPage === "Limits" ? "active" : ""}>Limits</a>
            <a href="/Scaleculus/Continuity/" class={currentPage === "Continuity" ? "active" : ""}>Continuity</a>
            <a href="/Scaleculus/Slope/" class={currentPage === "Slope" ? "active" : ""}>Slope</a>
            <a href="/Scaleculus/Differentiation/" class={currentPage === "Differentiation" ? "active" : ""}>Differentiation</a>
            <a href="/Scaleculus/Implicit/" class={currentPage === "Chain Rule and Implicit" ? "active" : ""}>Chain Rule and Implicit</a>

            <div class="Divider"></div>

            <a href="/Scaleculus/VideosLessons/" class={currentPage === "VideosLessons" ? "active" : ""}>Videos Lessons</a>
            <a href="/Scaleculus/Games/" class={currentPage === "Games" ? "active" : ""}>Games</a>

            <div class="Divider"></div>

            <a href="/Scaleculus/About/" class={currentPage === "About" ? "active" : ""}>About Us</a>
            
        </nav>
    </div>
</div>

<style>
:root {
    --wisteria: rgb(190, 173, 220);
    --shadow-grey: rgb(20, 21, 39);
    --snow: #F8EEEDff;
}

/* Permanent home button */
.Home-Button {
    position: fixed;
    top: 1rem;
    left: 1rem;
    width: 3rem;
    height: 3rem;
    border: solid rgb(17, 1, 31);
    border-radius: 0.5rem;
    background-color: rgb(220, 160, 255);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1001;
    transition: background 0.2s;
}

.Home-Button:hover {
    background-color: var(--wisteria);
}

.Home-Button img {
    width: 70%;
    height: auto;
    filter: invert(1);
}

/* Sidebar */
.Sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: 0;
    background-color: rgba(20,21,39,0.9);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-right: 2px solid var(--wisteria);
    box-shadow: 2px 0 10px rgba(193,142,199,0.5);
    overflow-x: hidden;
    transition: width 0.3s ease;
    z-index: 100;
}

/* Open sidebar */
.Sidebar[data-open="true"] {
    width: 18rem;
}

/* Sidebar content */
.Sidebar-Content {
    display: flex;
    flex-direction: column;
    padding: 5rem 1rem 2rem 1rem; /* top padding increased to 4rem */
    height: 100%;
    gap: 1rem;
    transform: translateX(-20px);
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
}

.Sidebar[data-open="true"] .Sidebar-Content {
    transform: translateX(0);
    opacity: 1;
}

/* Links */
.Sidebar-Content a {
    display: block;
    text-decoration: none;
    color: var(--snow);
    font-family: "Quicksand", sans-serif;
    font-size: 1.2rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    transition: background 0.2s, color 0.2s;

    white-space: nowrap;   /* prevents wrapping */
}

.Sidebar-Content a:hover {
    background-color: rgba(190,173,220,0.3);
}

.Sidebar-Content a.active {
    background-color: var(--wisteria);
    color: var(--shadow-grey);
    font-weight: 700;
}

/* Push main content */
.Sidebar[data-open="true"] ~ .Main-Content {
    margin-left: 18rem;
    transition: margin-left 0.3s ease;
}

.Divider {
    height: 2px;
    width: 85%;
    margin: 0.8rem auto;
    background: linear-gradient(
        90deg,
        transparent,
        var(--wisteria),
        transparent
    );
    border-radius: 999px;
    opacity: 0.7;
}

</style>

<script type="module">
document.addEventListener('DOMContentLoaded', () => {
    const sidebar = document.querySelector('.Sidebar');
    const homeButton = document.querySelector('.Home-Button');

    if (!sidebar || !homeButton) return;

    homeButton.addEventListener('click', () => {
        const isOpen = sidebar.getAttribute('data-open') === 'true';
        sidebar.setAttribute('data-open', !isOpen);
    });
});
</script>