---
const {direction, title, fontsize1, fontsize2, justifycontent, width, height} = Astro.props;
---

<main id={Astro.props.id} class="Info_Section" style={`
    --direction: ${direction};
    --fontsize1: ${fontsize1};
    --fontsize2: ${fontsize2};
    --justifycontent: ${justifycontent};
    --width: ${width};
    --height: ${height};
`}>
    <section class = "Info-Con">
        <header class="Title-Con">
            <img src="/Scaleculus/icons/arrow-right.png" alt="arrow icon" class = "Title-Icon" />
            <span class="Title-Text">{title}</span>
        </header>

        <div class="Line"></div>

        <section class="Info-Text">
            <slot />
        </section>
    </section> 
</main>

<style>
   .Info_Section {
    background-color: rgba(20, 21, 39, 0.05); /* softer */
    width: var(--width);
    min-height: var(--height);
    border-radius: 1rem;

    position: relative;
    overflow: auto;

    backdrop-filter: blur(20px); /* softer blur */
    -webkit-backdrop-filter: blur(20px); 

    border: none; /* remove borders */
    margin-top: 1rem;
    margin-bottom: 1rem;

    box-shadow: 0rem 0rem 0.25rem 0.01rem rgba(193, 142, 199, 0.3); /* softer shadow */
    padding: 1rem 1.5rem;

    color: var(--snow);
    z-index: 1;
}

.Info-Con {
    position: relative;
    padding: 0;
    text-align: var(--direction);
    white-space: normal;          
    overflow-wrap: break-word;   
    word-break: break-word;       
    z-index: 1;
}

.Title-Con {
    display: flex;
    align-items: center;  
    justify-content: var(--justifycontent);
    min-height: 4vh;
    gap: 0.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
}

.Title-Icon {
    width: 1.2rem; /* smaller, less distracting */
    height: auto;
    filter: invert(1) drop-shadow(2px 2px 4px rgba(190, 173, 220, 0.6));
}

.Title-Text {
    font-family: "Quicksand", sans-serif;
    font-size: var(--fontsize1);  
    font-weight: 700;
    color: var(--snow);
    text-shadow: 0 0 3px rgba(190, 173, 220, 0.4); /* subtle glow */
}

.Line {
    display: none; /* hide the line completely */
}

.Info-Text {
    position: relative;
    color: var(--snow);
    font-family: "Quicksand", sans-serif;
    font-weight: 500;
    font-size: var(--fontsize2);
    padding: 1rem;
    margin: 0; /* remove extra margin */
    border: none; /* remove left/right borders */
    background: rgba(231, 179, 255, 0.062); /* barely visible background */
    border-radius: 0.3rem;
    box-shadow: none; /* remove text shadowing */
    line-height: 1.6;
    
}

</style>