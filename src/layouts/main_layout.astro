---
import Topics from "../data/topics.json";

import Header from "../components/Header.astro";
import HorSection2 from "../components/Hor-Section2.astro";

import ColorPalette from "../color_p/color_style1.json";

import "../styles/style1.css";

const {title = "Scaleculus! | Calculus Learning Platform"} = Astro.props;

const numComets = 5;

const comets = Array.from({ length: numComets }, () => ({
  top: `-20vh`,     
  left: `${Math.random() * 60 - 50}vw`,
  duration: `${(3 + Math.random() * 2).toFixed(4)}s`, 
  delay: `${(1 + Math.random() * 8).toFixed(4)}s`         
}));

const mathIcons = ["∑","∫","∆","∂","∞","√","θ","≈","∇","dx"];

---
<!DOCTYPE html>
<html lang="en">
    <head>
	    <meta charset="UTF-8">
	    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="shortcut icon" type="image/x-icon" href="/Scaleculus/logo/Mascot.png" />
        
	    <title>{title}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Fugaz+One&family=Press+Start+2P&family=Quicksand:wght@300..700&display=swap" rel="stylesheet">


    </head>
    
	<body>
        <img class = "Background" src ="/Scaleculus/background/gradient_sky.jpg" alt="">

        <div class="Stars">
        {Array.from({ length: 50 }).map((_, i) => (
        <div
        class="Star"
        style={`
        top: ${Math.random() * 100}%;
        left: ${Math.random() * 100}%;
        font-size: ${Math.random() * 24 + 16}px;
        `}
        >
        {mathIcons[Math.floor(Math.random() * mathIcons.length)]}
        </div>
    ))}
    </div>

      <Header></Header>
      <slot />
      <HorSection2 title = "Made with ❤ from Scalable!" direction = "left">
        lol
      </HorSection2>
	</body>
</html>

<div class="Comets-Container">
    {comets.map((comet, i) => {
    return (
      <div
        class={`Comet comet${i}`}
        style={`top: ${comet.top}; left: ${comet.left}; animation-duration: ${comet.duration}; animation-delay: ${comet.delay};`}
      ></div>
    )
    })}
</div>

<style>
    body {
        background: var(--shadow-grey);
        min-height: 5000vh;
    }

    .Background {
        position: fixed;
        height: 100vh;
        width: 100vw;
        opacity: 1;
        background-size: cover;
        background-position: center;

        color: rgb(255,255,255);

        filter: blur(0px) hue-rotate(30deg) brightness(50%);
        z-index: 0;
        
    }

    .Comet {
    position: absolute;
    width: 30rem;
    height: 5px;
    background-color: rgb(254, 255, 246);         
    transform: rotate(45deg);

    filter: blur(3px);

    opacity: 0.5;  
    border-radius: 100%;
    animation: moveComet 2s ease-in-out infinite;
    }   
    
    .Comets-Container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    }


   @keyframes moveComet {
    0% {
        transform: translate(0px, 0px) rotate(45deg);
    }
    100% {
        transform: translate(1800px, 1600px) rotate(50deg);
    }
    }

    .Stars {
    position: fixed;
    inset: 0;
    pointer-events: none;

    user-select: none;

    z-index: 0;
    }

    .Star {
    position: absolute;
    color: white;
    text-shadow: 0 0 6px rgba(255,255,255,0.7), 0 0 12px rgba(255,255,255,0.5);
    will-change: transform;
    pointer-events: none;
    }

</style>    

<script>
const stars = document.querySelectorAll<HTMLElement>(".Star");
const viewportHeight = window.innerHeight;

// Store original positions
stars.forEach((star) => {
  star.dataset.origTop = star.offsetTop.toString();
});

let ticking = false;

function updateStars() {
  const scrollY = window.scrollY;

  stars.forEach((star, i) => {
    const speed = 0.1 + (i % 5) * 0.05;
    const origTop = parseFloat(star.dataset.origTop || "0");

    // Move star up
    let newY = (origTop - scrollY * speed) % (viewportHeight + 50);

    // Wrap star back into view if it goes above
    if (newY < -50) newY += viewportHeight + 50;

    star.style.transform = `translate3d(0, ${newY}px, 0)`;
  });

  ticking = false;
}

window.addEventListener("scroll", () => {
  if (!ticking) {
    requestAnimationFrame(updateStars);
    ticking = true;
  }
});
</script>
